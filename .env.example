# =====================================================
# .env.example — 環境変数テンプレート（GitHub 公開用）
# 実際の値は .env ファイルに記述し、.gitignore で除外する
# =====================================================

# LINE Login チャネル設定
# LINE Developers Console → チャネル基本設定 から取得
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:3000/callback

# LINE Messaging API（グループ通知用）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_GROUP_ID=

# Firebase Admin SDK サービスアカウントキー
# Firebase Console → プロジェクト設定 → サービスアカウント → 新しい秘密鍵を生成
# 取得した JSON の内容を 1 行にして貼り付ける
FIREBASE_SERVICE_ACCOUNT=
